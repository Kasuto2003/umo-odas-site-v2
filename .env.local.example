# ════════════════════════════════════════════════
# FICHIER : .env.local
# Renomme ce fichier en .env.local et remplis les valeurs
# NE JAMAIS COMMITTER CE FICHIER SUR GITHUB
# ════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Resend (envoi d'emails) ───────────────────
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Email qui reçoit les candidatures ─────────
CONTACT_EMAIL=umo@centre-odas.org

# ── URL de la plateforme Moodle ───────────────
NEXT_PUBLIC_MOODLE_URL=https://learn.umo.centre-odas.org
